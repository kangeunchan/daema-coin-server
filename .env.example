PORT=8080
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
PUBLIC_BASE_URL=http://localhost:5173
DATABASE_URL=postgres://daema:daema@localhost:5432/daema_coin?sslmode=disable
REDIS_URL=redis://localhost:6379/0
APP_TIMEZONE=Asia/Seoul
HTTP_MAX_JSON_BODY_BYTES=1048576

# GitHub OAuth
# GitHub OAuth App callback URL example:
# http://localhost:8080/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/github/callback
GITHUB_OAUTH_SCOPES=read:user user:email repo
# The "repo" scope is required for private repository commits.
GITHUB_COMMIT_MAX_PAGES=5
GITHUB_REPOSITORY_MAX_PAGES=10
GITHUB_APP_INSTALL_URL=
GITHUB_APP_INSTALL_ON_LOGIN=true
GITHUB_WEBHOOK_SECRET=
AUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/login

# Internal admin account bootstrap
# Set this only for first local bootstrap. The admin creates booth accounts from the admin API.
BOOTSTRAP_ADMIN_LOGIN=
BOOTSTRAP_ADMIN_PASSWORD=
INTERNAL_SESSION_TTL=12h

# API-FOOTBALL / API-SPORTS
# Docs: https://api-sports.io/documentation/football/v3
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEZONE=Asia/Seoul
API_FOOTBALL_WORLDCUP_LEAGUE=1
API_FOOTBALL_WORLDCUP_SEASON=2026
API_FOOTBALL_WORLDCUP_FROM=2026-06-11
API_FOOTBALL_WORLDCUP_TO=2026-07-19
API_FOOTBALL_CACHE_WORKER_ENABLED=true
API_FOOTBALL_CACHE_REFRESH_INTERVAL=1m
API_FOOTBALL_CACHE_TTL=5m
API_FOOTBALL_DETAIL_CACHE_REFRESH_INTERVAL=10m
API_FOOTBALL_DETAIL_CACHE_TTL=30m
API_FOOTBALL_DETAIL_CACHE_BEFORE=3h
API_FOOTBALL_DETAIL_CACHE_AFTER=4h
PREDICTION_SETTLEMENT_WORKER_ENABLED=true
PREDICTION_SETTLEMENT_INTERVAL=1m
